{
  "name": "studio",
  "version": "0.1.0",
  "publisher": "zensical",
  "displayName": "Zensical Studio",
  "description": "Visual Studio Code integration for Zensical Studio",
  "categories": [
    "Programming Languages"
  ],
  "homepage": "https://zensical.org/studio/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zensical/studio.git",
    "directory": "integrations/code"
  },
  "author": {
    "name": "Zensical",
    "email": "contributors@zensical.org"
  },
  "license": "MIT",
  "private": true,
  "main": "dist/extension.js",
  "files": [
    "dist",
    "language-configuration.json",
    "syntaxes",
    "package.json",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --outfile=dist/extension.js --external:vscode",
    "vsix": "npm run build && vsce package"
  },
  "dependencies": {
    "@zip.js/zip.js": "^2.8.26",
    "semver": "^7.8.4",
    "tar": "^7.4.3",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "keytar@7.9.0": true
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
    "onLanguage:python-markdown"
  ],
  "contributes": {
    "configurationDefaults": {
      "[python-markdown]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 4,
        "editor.wordBasedSuggestions": "off"
      }
    },
    "languages": [
      {
        "id": "python-markdown",
        "aliases": [
          "Python Markdown"
        ],
        "extensions": [
          ".md"
        ],
        "configuration": "./language.json"
      }
    ],
    "grammars": [
      {
        "language": "python-markdown",
        "scopeName": "text.html.markdown.python",
        "path": "./syntaxes/python-markdown.tmLanguage.json",
